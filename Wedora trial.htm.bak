  <script>
    // ── LOGO SWAP (replace placeholder with real logo once uploaded) ──
    // To use your real logo, replace the src below with your logo file path
    const LOGO_SRC = 'YOUR_LOGO.png'; // ← replace this
    // For now we render a text fallback
    document.querySelectorAll('#loader-logo, #nav-logo-img, #footer-logo').forEach(el => {
      el.onerror = function () {
        const canvas = document.createElement('canvas');
        canvas.width = 120; canvas.height = 60;
        const ctx = canvas.getContext('2d');
        ctx.fillStyle = '#D4AF37';
        ctx.font = 'italic 28px Georgia';
        ctx.fillText('Wedora', 8, 42);
        el.src = canvas.toDataURL();
      };
      el.src = LOGO_SRC;
      el.onerror();
    });

    // ── LOADER ──
    window.addEventListener('load', () => {
      setTimeout(() => {
        document.getElementById('loader').classList.add('hide');
      }, 2400);
    });

    // ── NAV SCROLL ──
    const navbar = document.getElementById('navbar');
    window.addEventListener('scroll', () => {
      navbar.classList.toggle('scrolled', window.scrollY > 60);
    });

    // ── HERO SLIDESHOW ──
    const slides = document.querySelectorAll('.hero-slide');
    const dotsContainer = document.getElementById('heroDots');
    let currentSlide = 0;

    slides.forEach((_, i) => {
      const dot = document.createElement('div');
      dot.className = 'hero-dot' + (i === 0 ? ' active' : '');
      dot.addEventListener('click', () => goToSlide(i));
      dotsContainer.appendChild(dot);
    });

    function goToSlide(n) {
      slides[currentSlide].classList.remove('active');
      dotsContainer.children[currentSlide].classList.remove('active');
      currentSlide = n;
      slides[currentSlide].classList.add('active');
      dotsContainer.children[currentSlide].classList.add('active');
    }

    setInterval(() => {
      goToSlide((currentSlide + 1) % slides.length);
    }, 5000);

    // ── MARQUEE ──
    const items = [
      'Wedding Décor', 'Floral Design', 'Royal Themes',
      'Stage & Lighting', 'Venue Styling', 'Carnival Activities',
      'Udaipur Weddings', 'Kumbhalgarh Events', 'Vendor Coordination',
      'Destination Weddings', 'Hospitality', 'Theme Management'
    ];
    const track = document.getElementById('marqueeTrack');
    [...items, ...items].forEach(item => {
      track.innerHTML += `<div class="marquee-item"><span class="dot"></span>${item}</div>`;
    });

    // ── SCROLL REVEAL ──
    const revealEls = document.querySelectorAll('.reveal');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          observer.unobserve(e.target);
        }
      });
    }, { threshold: 0.12 });
    revealEls.forEach(el => observer.observe(el));

    // ── COUNTER ANIMATION ──
    const counters = document.querySelectorAll('.counter');
    const counterObserver = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          const target = +e.target.dataset.target;
          let count = 0;
          const step = target / 60;
          const timer = setInterval(() => {
            count = Math.min(count + step, target);
            e.target.textContent = Math.floor(count);
            if (count >= target) clearInterval(timer);
          }, 25);
          counterObserver.unobserve(e.target);
        }
      });
    }, { threshold: 0.5 });
    counters.forEach(c => counterObserver.observe(c));

    // ── GALLERY FILTER ──
    function filterGallery(btn, theme) {
      document.querySelectorAll('.theme-tag').forEach(t => t.classList.remove('active'));
      btn.classList.add('active');
      document.querySelectorAll('.gallery-item').forEach(item => {
        const match = theme === 'all' || item.dataset.theme === theme;
        item.style.opacity = match ? '1' : '0.15';
        item.style.transform = match ? 'scale(1)' : 'scale(0.97)';
        item.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
      });
    }

    // ── TESTIMONIALS ──
    const tSlides = document.querySelectorAll('.testimonial-slide');
    const tNav = document.getElementById('testimonialNav');
    let currentT = 0;

    tSlides.forEach((_, i) => {
      const dot = document.createElement('div');
      dot.className = 't-dot' + (i === 0 ? ' active' : '');
      dot.addEventListener('click', () => goToTestimonial(i));
      tNav.appendChild(dot);
    });

    function goToTestimonial(n) {
      tSlides[currentT].classList.remove('active');
      tNav.children[currentT].classList.remove('active');
      currentT = n;
      tSlides[currentT].classList.add('active');
      tNav.children[currentT].classList.add('active');
    }

    setInterval(() => {
      goToTestimonial((currentT + 1) % tSlides.length);
    }, 6000);

    // ── MOBILE MENU ──
    function openMobileMenu() {
      document.getElementById('mobileMenu').classList.add('open');
      document.body.style.overflow = 'hidden';
    }
    function closeMobileMenu() {
      document.getElementById('mobileMenu').classList.remove('open');
      document.body.style.overflow = '';
    }
  </script>
</body>

</html>